<!DOCTYPE html>
<html>
<head>
    <title>Expense Tracker</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        body {
            background: linear-gradient(to right, #4e73df, #1cc88a);
            min-height: 100vh;
        }

        /* Top Summary Cards */
        .summary-card {
            border-radius: 15px;
            padding: 20px;
            color: white;
        }

        .summary-expense {
            background: linear-gradient(135deg, #3b82f6, #2563eb);
        }

        .summary-count {
            background: linear-gradient(135deg, #22c55e, #15803d);
        }

        /* Expense Cards */
        .expense-card {
            border-radius: 15px;
            transition: 0.2s ease;
        }

        .expense-card:hover {
            transform: translateY(-3px);
        }

        .amount {
            font-size: 1.1rem;
            font-weight: 600;
            color: #dc3545;
        }

        .small-text {
            font-size: 0.85rem;
        }
    </style>
</head>

<body>

<div class="container py-4">

    <!-- Summary Section -->
    <div class="row g-3 mb-4">
        <div class="col-6">
            <div class="summary-card summary-expense text-center shadow">
                <h6>Total Expenses</h6>
                <h4 class="fw-bold">₹ <%= total %></h4>
            </div>
        </div>

        <div class="col-6">
            <div class="summary-card summary-count text-center shadow">
                <h6>Total Entries</h6>
                <h4 class="fw-bold"><%= expenses.length %></h4>
            </div>
        </div>
    </div>

    <!-- Add Button -->
    <div class="d-grid mb-4">
        <a href="/add" class="btn btn-light btn-lg shadow-sm">
            <i class="bi bi-plus-circle"></i> Add Expense
        </a>
    </div>

    <!-- If No Expenses -->
    <% if (expenses.length === 0) { %>
        <div class="text-center text-white">
            <h5>No expenses added yet</h5>
        </div>
    <% } %>

    <!-- Expense Cards -->
    <% expenses.forEach(exp => { %>

        <div class="card shadow-sm mb-3 expense-card">
            <div class="card-body p-3">

                <div class="d-flex justify-content-between align-items-center">
                    <h6 class="mb-1">
                        <i class="bi bi-receipt"></i> <%= exp.title %>
                    </h6>
                    <span class="amount">₹ <%= exp.amount %></span>
                </div>

                <div class="d-flex justify-content-between mt-2">
                    <span class="badge bg-info text-dark small-text">
                        <i class="bi bi-tags"></i> <%= exp.category %>
                    </span>

                    <small class="text-muted small-text">
                        <i class="bi bi-calendar"></i> 
                        <%= new Date(exp.date).toDateString() %>
                    </small>
                </div>

                <div class="text-end mt-2">
                    <form action="/delete/<%= exp.id %>?_method=DELETE" method="POST">
                        <button class="btn btn-sm btn-outline-danger px-2 py-1">
                            <i class="bi bi-trash"></i>
                        </button>
                    </form>
                </div>

            </div>
        </div>

    <% }) %>

</div>

</body>
</html>